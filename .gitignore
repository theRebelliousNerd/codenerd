# OS noise
Thumbs.db
.DS_Store
*.tmp
*.temp
nul
*.log
debug_output*.txt
debug_program_ERROR*.mg

# Caches
**/__pycache__/
*.pyc
*.pyo
*.pyd
.cache/

# Temporary folders
tmp/
tmp_*/
tmp*/

# Research / planning scratch folders
Docs/research/
Docs/plans/
Docs/Spec/

# Local runtime / tooling state
/conductor/
/scripts/
/script/
/tools/
/data/traces/

# Hidden runtime/config paths
.nerd/

# Ignore any config.json payload (and derivatives) to prevent secret leakage.
**/config.json
**/config.*.json
config.json

# Local model prompt files
**/CLAUDE.md
**/claude.md
**/GEMINI.md
**/gemini.md

# SQLite/runtime artifacts
*.db-shm
*.db-wal
*.db-journal
*.sqlite-journal
*.sqlite3-journal
*.backup_*
